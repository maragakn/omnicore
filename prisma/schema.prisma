// SQLite does not support native enums.
// String fields are used instead; valid values are enforced via Zod and TypeScript enums in lib/constants/enums.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Center {
  id             String    @id @default(cuid())
  name           String
  code           String    @unique
  // CenterStatus: ACTIVE | ONBOARDING | INACTIVE
  status         String    @default("ONBOARDING")
  address        String
  city           String
  pincode        String
  capacity       Int
  gymSqFt          Int?
  // Numeric ID returned by center-service after quote acceptance
  externalCenterId Int?
  operatingSince   DateTime?
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  residentialDetails ResidentialDetails?
  myGateConfig       MyGateConfig?
  modules            CenterModule[]
  serviceConfigs     ServiceConfig[]
  equipmentAssets    EquipmentAsset[]
  trainerMappings    CenterTrainerMapping[]
  trainerAttendances TrainerAttendance[]
  amenityBookings    AmenityBooking[]
  serviceRequests    ServiceRequest[]
  ptSessions         PTSession[]
  lead               Lead?
}

// Tracks which modules/capabilities are enabled for a center.
// Drives which onboarding steps appear and which CF Admin sections are accessible.
// CenterModule.moduleKey valid values: TRAINERS | ASSETS | VENDING_MACHINES | BRANDING | MYGATE
model CenterModule {
  id        String   @id @default(cuid())
  centerId  String
  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  // moduleKey: TRAINERS | ASSETS | VENDING_MACHINES | BRANDING | MYGATE
  moduleKey String
  isEnabled Boolean  @default(true)
  config    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, moduleKey])
}

model ResidentialDetails {
  id                 String   @id @default(cuid())
  centerId           String   @unique
  center             Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  rwaName            String
  totalUnits         Int
  contactPersonName  String
  contactPersonPhone String
  contactPersonEmail String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AmenityBooking {
  id         String   @id @default(cuid())
  centerId   String
  center     Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  // MyGate member identifier (stubbed for demo)
  memberId   String?
  memberName String
  // Flat/apartment number, e.g. "A-204"
  memberFlat String?
  // Date of the booking slot (midnight UTC)
  slotDate   DateTime
  // Hour of slot: 6 = 6am–7am, 7 = 7am–8am, ..., 21 = 9pm–10pm
  slotHour   Int
  // status: BOOKED | CANCELLED
  status     String   @default("BOOKED")
  bookedAt   DateTime @default(now())
  createdAt  DateTime @default(now())
}

model MyGateConfig {
  id           String    @id @default(cuid())
  centerId     String    @unique
  center       Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  societyId    String
  apiKey       String
  webhookUrl   String?
  isActive     Boolean   @default(false)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ServiceConfig {
  id          String   @id @default(cuid())
  centerId    String
  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  serviceName String
  // ServiceType: MEMBERSHIP | PT | GROUP_CLASS | ADD_ON
  serviceType String
  monthlyFee  Float
  setupFee    Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EquipmentAsset {
  id             String    @id @default(cuid())
  centerId       String
  center         Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  name           String
  category       String
  brand          String?
  model          String?
  serialNumber   String?
  purchasedOn    DateTime?
  warrantyExpiry DateTime?
  lastServicedOn DateTime?
  nextServiceDue DateTime?
  // AssetCondition: GOOD | FAIR | POOR
  condition      String    @default("GOOD")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  serviceRequests ServiceRequest[]
}

model Trainer {
  id             String    @id @default(cuid())
  name           String
  phone          String
  email          String?
  // TrainerType: FULLTIME | PT
  trainerType    String    @default("FULLTIME")
  specialization String?
  certifications String?
  joinedOn       DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  centerMappings CenterTrainerMapping[]
  attendances    TrainerAttendance[]
  ptSessions     PTSession[]
}

model CenterTrainerMapping {
  id         String   @id @default(cuid())
  centerId   String
  center     Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  trainerId  String
  trainer    Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  assignedOn DateTime @default(now())
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([centerId, trainerId])
}

model TrainerAttendance {
  id        String    @id @default(cuid())
  centerId  String
  center    Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  trainerId String
  trainer   Trainer   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  // AttendanceSource: MYGATE | OTP | MANUAL
  source    String    @default("MANUAL")
  // AttendanceStatus: PRESENT | ABSENT | LATE
  status    String    @default("PRESENT")
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([centerId, trainerId, date])
}

model PTSession {
  id           String   @id @default(cuid())
  centerId     String
  center       Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  trainerId    String
  trainer      Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  sessionDate  DateTime
  durationMins Int      @default(60)
  ratePerHour  Float
  memberName   String?
  isPaid       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ServiceRequest {
  id          String    @id @default(cuid())
  centerId    String
  center      Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  assetId     String?
  asset       EquipmentAsset? @relation(fields: [assetId], references: [id])
  title       String
  description String?
  // ServiceRequestStatus: OPEN | ASSIGNED | IN_PROGRESS | RESOLVED
  status      String    @default("OPEN")
  // ServiceRequestPriority: LOW | MEDIUM | HIGH | CRITICAL
  priority    String    @default("MEDIUM")
  reportedBy  String?
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Lead {
  id              String   @id @default(cuid())
  societyName     String
  contactName     String
  contactEmail    String
  contactPhone    String?
  // status: INVITED | FORM_SUBMITTED | QUOTE_SENT | ACCEPTED | ACTIVE | REJECTED
  status          String   @default("INVITED")
  inviteToken     String   @unique
  inviteExpiresAt DateTime
  // JSON snapshot of the RWA Admin's wizard submission (LeadFormSubmitSchema shape)
  formData        String?
  centerId        String?  @unique
  center          Center?  @relation(fields: [centerId], references: [id])
  quote           Quote?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Quote {
  id          String          @id @default(cuid())
  leadId      String          @unique
  lead        Lead            @relation(fields: [leadId], references: [id])
  // status: DRAFT | SENT | ACCEPTED | REJECTED
  status      String          @default("DRAFT")
  notes       String?
  sentAt      DateTime?
  acceptedAt  DateTime?
  lineItems   QuoteLineItem[]
  // quoteMode: ITEMIZED | TOTAL
  // ITEMIZED = per-module line items; TOTAL = single agreed total amount
  quoteMode   String          @default("ITEMIZED")
  // totalAmount in paise — only used when quoteMode = TOTAL
  totalAmount Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model QuoteLineItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  moduleKey   String
  // pricingType: MONTHLY | ONE_TIME | ONE_TIME_PLUS_TAKE_RATE
  pricingType String
  // oneTimeFee and monthlyFee are in paise (₹1 = 100 paise)
  oneTimeFee  Int?
  monthlyFee  Int?
  takeRatePct Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServicePricingConfig {
  id                 String   @id @default(cuid())
  moduleKey          String   @unique
  // pricingType: MONTHLY | ONE_TIME | ONE_TIME_PLUS_TAKE_RATE
  pricingType        String
  // defaultOneTimeFee and defaultMonthlyFee are in paise (₹1 = 100 paise)
  defaultOneTimeFee  Int?
  defaultMonthlyFee  Int?
  defaultTakeRatePct Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model EquipmentRecommendation {
  id           String   @id @default(cuid())
  // sizeCategory: SMALL | MEDIUM | LARGE
  sizeCategory String   @unique
  // JSON: [{ sku, name, category, qty }] — references EquipmentCatalogItem.sku
  items        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Master catalog of Cultsport commercial equipment (from Commercial Catalog 2025 PDF).
// Seeded once and used for recommendations, wizard selection, and CF Admin quote builder.
model EquipmentCatalogItem {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  // category: TREADMILL | ELLIPTICAL | BIKE | HIGH_INTENSITY | STRENGTH_FLOW | STRENGTH_FLUX |
  //           STRENGTH_FUEL | STRENGTH_FORCE | CABLE_FUNCTIONAL | BENCH | FREE_WEIGHTS |
  //           KETTLEBELL | ACCESSORIES
  category    String
  series      String?  // FLOW | FLUX | FUEL | FORCE (for strength selectorized machines)
  imageUrl    String?  // /equipment/{category-slug}-1.jpg
  imageUrl2   String?  // /equipment/{category-slug}-2.jpg (gym-in-use shot)
  specsJson   String?  // key specs as display string
  isHighlight Boolean  @default(false) // included in baseline model gym setup
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
