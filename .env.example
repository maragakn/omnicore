# Copy this file to .env and fill in the values.
# .env is gitignored — never commit actual secrets.

# SQLite (local dev) — this default value works out of the box
DATABASE_URL="file:./dev.db"

# When switching to Postgres (production), use:
# DATABASE_URL="postgresql://user:password@localhost:5432/omnicore"

# Trino (Curefit Data Platform) — used for AMS asset/SR/WO reports
# Schema: datalake.pk_prod_cultsport_asset_management_service
TRINO_HOST="dataplatform-trino.curefit.co"
TRINO_USER="fitness-analysts"
TRINO_PASSWORD="your-password-here"
TRINO_CATALOG="delta"
TRINO_SCHEMA="pk_prod_cultsport_asset_management_service"

# Center-service — registers the center in Curefit's platform after quote acceptance
# Staging: center-service.stage.cure.fit.internal
# Leave blank in local dev to skip (center is still created locally)
CENTER_SERVICE_URL="center-service.stage.cure.fit.internal"
CENTER_SERVICE_USER_ID="123456"

# Demo MyGate proxy (POST /api/demo/mygate-proxy/booking) — optional shared secret
# If set, callers must send header x-demo-secret with this value
# DEMO_MYGATE_PROXY_SECRET=""
